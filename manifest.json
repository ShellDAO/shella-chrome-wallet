{
  "manifest_version": 3,
  "name": "Shella Wallet",
  "version": "0.2.0",
  "description": "Post-quantum Chrome wallet for Shell Chain",
  "permissions": ["storage", "alarms"],
  "host_permissions": [],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
